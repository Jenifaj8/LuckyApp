@{
    ViewData["Title"] = "Pick 4";
}

<div class="py-5" style="background-color: #fff1f6; min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-5">
                        <h1 class="mb-3">Pick 4</h1>
                        <p class="text-muted mb-4">
                            Choose the draw type and enter a 4-digit number.
                        </p>

                        <form method="post">
                            <div class="mb-4">
                                <label class="form-label fw-semibold">Draw Type</label>
                                <select name="drawType" class="form-select form-select-lg rounded-3">
                                    <option value="">Select draw</option>
                                    <option value="Midday" selected="@(ViewBag.SelectedDrawType == "Midday")">Midday</option>
                                    <option value="Evening" selected="@(ViewBag.SelectedDrawType == "Evening")">Evening</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">4-Digit Number</label>
                                <input type="text"
                                       name="pick4Number"
                                       class="form-control form-control-lg rounded-3"
                                       maxlength="4"
                                       placeholder="e.g. 1579" />
                                <div class="form-text">Enter exactly 4 digits.</div>
                            </div>

                            <button type="submit" class="btn btn-success btn-sm rounded-3 px-4">Generate</button>
                        </form>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger mt-4 rounded-3">
                                @ViewBag.Error
                            </div>
                        }

                        @if (ViewBag.Result != null)
                        {
                            var resultDigits = ViewBag.Result.ToString().ToCharArray();

                            <div class="mt-5">
                                <h3 class="mb-2">Generated Result</h3>
                                <p class="text-muted mb-3">Draw Type: <strong>@ViewBag.SelectedDrawType</strong></p>

                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var digit in resultDigits)
                                    {
                                        <div class="rounded-circle bg-light border d-flex justify-content-center align-items-center fw-bold"
                                             style="width: 65px; height: 65px; font-size: 1.3rem;">
                                            @digit
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>